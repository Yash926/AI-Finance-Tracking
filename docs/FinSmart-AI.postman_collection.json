{
  "info": {
    "name": "FinSmart AI – API Collection",
    "_postman_id": "finsmart-ai-v1",
    "description": "Complete REST API collection for FinSmart AI – Intelligent Personal Finance Assistant.\n\n**Base URL:** `http://localhost:5000/api`\n\n**Auth:** All protected routes require the `Authorization: Bearer <token>` header. Run the Login or Register request first, copy the `token` from the response, then set the `token` collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token",   "value": "",                          "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health" },
            "description": "Verify the server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Yash Tripathi\",\n  \"email\": \"yash@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "description": "Create a new user account. Automatically saves the JWT token to the `token` collection variable."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"yash@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "description": "Authenticate and receive a JWT token."
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/profile" },
            "description": "Get the authenticated user's profile. Requires JWT."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Add Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/transactions" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"amount\": 1200,\n  \"category\": \"Food\",\n  \"description\": \"Lunch at restaurant\",\n  \"date\": \"2025-03-15\"\n}"
            },
            "description": "Add a new income or expense transaction.\n\n**income categories:** Salary, Freelance, Investment, Gift, Other Income\n\n**expense categories:** Food, Transport, Shopping, Entertainment, Health, Education, Utilities, Rent, Travel, Other Expense"
          },
          "response": []
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions?page=1&limit=20",
              "query": [
                { "key": "type",      "value": "expense",    "disabled": true, "description": "Filter: income | expense" },
                { "key": "category",  "value": "Food",       "disabled": true },
                { "key": "startDate", "value": "2025-03-01", "disabled": true },
                { "key": "endDate",   "value": "2025-03-31", "disabled": true },
                { "key": "page",      "value": "1" },
                { "key": "limit",     "value": "20" }
              ]
            },
            "description": "Paginated list of transactions with optional filters."
          },
          "response": []
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/transactions/:id", "variable": [{ "key": "id", "value": "TRANSACTION_ID" }] }
          },
          "response": []
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/transactions/:id", "variable": [{ "key": "id", "value": "TRANSACTION_ID" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1500,\n  \"description\": \"Updated description\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/transactions/:id", "variable": [{ "key": "id", "value": "TRANSACTION_ID" }] }
          },
          "response": []
        },
        {
          "name": "Monthly Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions/summary?month=3&year=2025",
              "query": [
                { "key": "month", "value": "3" },
                { "key": "year",  "value": "2025" }
              ]
            },
            "description": "Returns totalIncome, totalExpense, netBalance, and category breakdown for a given month."
          },
          "response": []
        },
        {
          "name": "Monthly Trend (12 months)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions/monthly-trend?year=2025",
              "query": [{ "key": "year", "value": "2025" }]
            },
            "description": "Returns income and expense totals for each month of the given year (used for the line chart)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Budget",
      "item": [
        {
          "name": "Set Budget",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/budget" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"month\": 3,\n  \"year\": 2025,\n  \"totalLimit\": 50000,\n  \"categoryLimits\": [\n    { \"category\": \"Food\",        \"limit\": 8000 },\n    { \"category\": \"Transport\",   \"limit\": 3000 },\n    { \"category\": \"Shopping\",    \"limit\": 5000 },\n    { \"category\": \"Utilities\",   \"limit\": 4000 }\n  ]\n}"
            },
            "description": "Create or update the monthly budget. An existing budget for the same month/year is overwritten (upsert)."
          },
          "response": []
        },
        {
          "name": "Get Budget & Alerts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/budget?month=3&year=2025",
              "query": [
                { "key": "month", "value": "3" },
                { "key": "year",  "value": "2025" }
              ]
            },
            "description": "Returns the saved budget, current spend, percentage used, and any danger/warning alerts."
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI Insights",
      "item": [
        {
          "name": "Generate AI Insights",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/ai/insights?month=3&year=2025",
              "query": [
                { "key": "month", "value": "3" },
                { "key": "year",  "value": "2025" }
              ]
            },
            "description": "Sends the user's transaction summary to Google Gemini API and returns human-readable financial advice. Falls back to rule-based mock insights if the API key is not configured."
          },
          "response": []
        }
      ]
    }
  ]
}
